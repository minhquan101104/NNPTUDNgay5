<!DOCTYPE html>
<html>
<head>
    <title>Error</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 50px;
            text-align: center;
        }
        h1 {
            color: #e74c3c;
        }
        pre {
            background: #f4f4f4;
            padding: 20px;
            border-radius: 5px;
            text-align: left;
            display: inline-block;
        }
    </style>
</head>
<body>
    <h1><%= message %></h1>
    <h2><%= error.status %></h2>
    <pre><%= error.stack %></pre>
</body>
</html>
